}

@inproceedings{Khazi2020RealTimeInsitu,
  title = {Real Time In-Situ Quality Monitoring of Grinding Process Using Microtechnology Based Sensor Fusion},
  booktitle = {2020 {{IEEE International Conference}} on {{Semiconductor Electronics}} ({{ICSE}})},
  author = {Khazi, Isman and Kovacs, Andras and Zahedi, Ali and Reser, Christian and Mescheder, Ulrich and Azarhoushang, Bahman and Reich, Christoph},
