}

@article{Zhang2019SiliconCarbideSurface,
  title = {Silicon Carbide Surface Quality Prediction Based on Artificial Intelligence Methods on Multi-Sensor Fusion Detection Test Platform},
  author = {Zhang, Yawei and Li, Beizhi and Yang, Jianguo and Liu, Xiao and Zhou, Jinqiang},
  year = {2019},
