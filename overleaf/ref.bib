  month = jul,
  pages = {180--184},
  doi = {10.1109/ICSE49846.2020.9166898},
  urldate = {2025-02-24},
  abstract = {An innovative approach of non-destructive detection of grinding burn is developed using sensor fusion of an optical sensor and a miniaturized eddy-current sensor, which is realized with a 2D microfabricated planar micro-coil. Additionally, an in-situ cloud-compatible system is proposed for the real-time predictive and preventive monitoring of the workpiece burn in cylindrical grinding process of a hardened 42CrMo4 steel. A reference workpiece, ground with different grinding burn levels, was investigated with the two sensors. The test results show a comprehensive correlation between the process input parameters and the degree of grinding burn on one hand, and the light reflection intensity and impedance response of the micro-coil on the other hand. The test outputs on the reference workpiece are further used for the training of the cloud monitoring system.},
  keywords = {cloud computing,Coils,eddy-current test,grinding burn,industrial revolution 4.0,microfabrication,Monitoring,non-destructive testing (NDT),Optical fiber sensors,Optical fibers,optical sensor,real-time monitoring,sensor fusion,Sensor fusion},
