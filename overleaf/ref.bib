@article{Feng2023CorrelationVibrationSignal,
  title = {Correlation between Vibration Signal and Surface Quality Based on Recurrence Analysis during Surface Burnishing Process},
  author = {Feng, Shiqing and Ding, Cong and Qiao, Zhizhao and Yuan, Zhipeng and Zhou, Zhenyu and Hou, Wentao and Piao, Zhongyu},
  year = {2023},
  month = oct,
  journal = {Mechanical Systems and Signal Processing},
  volume = {200},
  pages = {110654},
  issn = {0888-3270},
  doi = {10.1016/j.ymssp.2023.110654},
  urldate = {2025-02-28},
  abstract = {Surface burnishing process (SBP) is the use of balls to plastically deform the sample surface to finishing processing, but its internal dynamic behaviors are poorly studied. Here we reported that the vibration signal performances extracted from the SBP system based on recurrence plot (RP). A novel denoised method based on EEMD and power spectrum was introduced. The correlation between the vibration signal and the surface quality was explored. The experimental results showed that via SBP, the surface roughness parameters Ra and Sa of the sample were reduced to 0.066~{$\mu$}m and 0.217~{$\mu$}m, respectively. And the cross-sectional hardness for region B in test 7 reached 206 HV. The proposed denoised method achieve effective information as much as possible from the original signals. The threshold for constructing a recurrence plot (RP) was determined by a fix recurrence rate RR~=~0.1. The RP changed dramatically depending on the different paths created by the different loading force directions. The cross paths of the loading force (i.e. region B) corresponded to a more uniform RP and a more stable system. Under the interaction of burnishing depth, spindle speed and feed rate, the evolution trend of cross-sectional hardness was opposite to the recurrence quantitative analysis (RQA) parameters: DET, LAM, and RPDE. The largest cross-sectional hardness corresponded to the least DET, LAM, and RPDE. It indicated that the sample surface quality was reflected by the recurrence characteristics of vibration signals. This research provides a way for using processing system signals to predict the sample surface quality. Conclusions The major thing we proposed in this research was an innovative denoised method based on EEMD and power spectrum. The effect of input parameters on recurrence plots and the system dynamics changed during the SBP using RPs were investigated. Additionally, a link was established between surface quality and RQA. The key findings are as follows: (1) The key innovation of a novel denoised approach based on EEMD and power spectrum was the selection of IMF based on the number of spikes in the power spectrum plot of the IMF components. For test 1, the power spectrum spikes were nearly non-existent after IMF7, so IMF7-17 and the residual component were chosen. This method was based on the characteristics of the signal itself. so that the noise-reduced signal and the effective signal are as close as possible. The method can effectively overcome the application flaws in the earlier methods, quickly discriminate the noise content of IMF components and reasonably select IMF for signal reconstruction. It can prevent excessive noise components of the reconstructed signal caused by poor component selection, and it aids in identifying the signal characteristics and reflecting the system true dynamic characteristics. (2) The recurrence points density of the RPs was influenced by the embedding dimension, time delay, and threshold. The structure of the RPs was influenced by threshold. When the threshold, embedding dimension, and time delay were too small, the full dynamic information cannot be accurately reflected. Additionally, if the values were too high, artificial points start to appear, which caused distortion. As a result, in this study the optimal time delay and embedding dimension selection are handled by the mutual information method and the false proximity method, respectively, while the threshold is chosen using the fixed RR approach. Then, the vibration signal RPs is plotted. Set {$\tau$} = 11, m = 6, fixed RR = 0.1. And the SBP full machining path conformed to disrupted, with the RP changing abruptly depending on the various paths generated by the various loading force directions. The cross paths of the loading force (i.e. region B) corresponded to a more uniform RP and a more stable system. (3) The system performances were described using DET, LAM, and RPDE of RQA parameters. The surface quality characterization parameters of the sample in the SBP were based on the cross-section hardness. When the spindle speed was constant, the system stability decreases and the cross-sectional hardness increased as the burnishing depth and feed speed decreases. The system of test 1 was the most stable in tests 1, 4, and 7. When the burnishing depth was constant, the system stability decreased and the cross-sectional hardness increased as the spindle speed and feed speed decreased. Showing the tests 1 system to be the most stable again in tests 1, 2, and 3. When the feed speed was constant, the system stability declines and the cross-sectional hardness rise with the spindle speed increases and the burnishing depth dropped. The test 5 system was the most stable in tests 3, 5, and 7. Interaction exists between the machining parameters (burnishing depth, spindle speed, and feed rate) and the sample cross-sectional hardness. Realizing that the three RQA parameters and cross-sectional hardness are inversely related. The surface quality of the sample can be captured by the machining process signal recurrence characteristics.},
  keywords = {EEMD,Hardness,RP,RQA,Surface burnishing process},
  annotation = {JCR分区: Q1\\
中科院分区升级版: 工程技术1区\\
影响因子: 7.9\\
5年影响因子: 8.0}
}

@article{GarciaPlaza2019EfficiencyVibrationSignal,
  title = {Efficiency of Vibration Signal Feature Extraction for Surface Finish Monitoring in {{CNC}} Machining},
  author = {Garc{\'i}a Plaza, E. and N{\'u}{\~n}ez L{\'o}pez, P. J. and Beamud Gonz{\'a}lez, E. M.},
  year = {2019},
  month = aug,
  journal = {Journal of Manufacturing Processes},
  volume = {44},
  pages = {145--157},
  issn = {1526-6125},
  doi = {10.1016/j.jmapro.2019.05.046},
  urldate = {2025-02-28},
  abstract = {On-line monitoring technologies in CNC machining operations eliminate post-process quality control, and are crucial for improving productivity and reliability, reducing production times and costs, and enhancing automation of the process. The appropriate selection of sensors, signal feature extraction methods, and parametric characterization techniques are critical aspects influencing the quality of predictions and system response times. This paper examined four signal feature extraction methods to optimize surface finish monitoring by focusing on the analysis of vibration signals in order to correlate signal statistical measurements and frequency bands with surface roughness. Thus, a single low cost sensor (accelerometer) easily implemented in CNC turning machine was used to make in-process decisions on product surface finish. Two non-advanced signal feature extraction methods (time direct analysis TDA, and power spectral density PSD), and two advanced methods (singular spectrum analysis SSA, and wavelet packet transform WPT) were assessed. The results show that the advanced methods (SSA and WPT) permitted optimum vibration signal feature extraction, but the SSA method exhibited a high computational cost. The WPT provided the excitation ranges that correlate the vibration parametric features with surface finish. The vibration signal and WPT method can be used effectively for real-time surface finish monitoring with high accuracy, reliability, and a low analytical-computational cost in CNC machining. This work is innovative in revealing that not all vibration feature extraction methods are appropriate for the real-time monitoring of surface finish, and that on-line surface quality control is possible with a low cost sensor easily implemented in CNC machine tools. Conclusions In this study the most extensively used signal feature extraction methods applied for the monitoring of surface finish in automated CNC machining operations were analysed. Two easily applied non-advanced signal processing methods (TDA and PSD), and the fusion of both methods (TDA\,+\,PSD) were evaluated. Moreover, two advanced methods (SSA and WPT) that decompose the signal in the combined time-frequency domain, with greater analytical complexity and computational cost were assessed. Surface finish was monitored through the individual analysis of the Cartesian vibration components (ax, ay, az), and the fused analysis  , in order to determine the amount of information provided by each vibration component (ai), the degree of self-correlation, and the effectiveness of fusing the Cartesian components applied in each processing method. The predictive power, reliability, and response times for each processing method were determined by applying the same experimental design. The correlation found between certain orthogonal vibration components justified the fusion of the orthogonal components  , as opposed to using the resultant vector module  , which prevented the input of redundant information in the models predictive, and in turn a fall in predictive efficiency. The fusion of the orthogonal vibration components   improved the predictive results and reliability as compared to each single component (ai) in all of the methods assessed. This highlighted that the components were complementary and the fusion improved signal feature extraction, in spite of the correlation between the vibration components (ai). The feed vibration component ay was the primary information source for the monitoring of surface finish, which was complemented by the tangential az and radial ax components that improved the prediction of surface finish as a secondary source of information. As for signal statistical parameterization, the parameter arithmetic mean (Xi) estimating the central value of the signal and the standard deviation ({$\sigma$}i) characterizing the dispersion were the most significant characterization parameters, and the best option for statistical feature extraction. The non-advanced signal processing methods (TDA, PSD, TDA\,+\,PSD) failed to obtain optimum signal feature extraction, and the results obtained with the PSD technique were unsatisfactory, with moderate results for the TDA method. The fusion of both methods slightly improved the results, which were far below the prediction levels of the advanced methods. The decomposition into principal components of the SSA method enabled the isolation and location of signal areas with effective information for the monitoring of surface finish, with all of the principal components of the grouped eigenvalues {$\lambda$}1-2, {$\lambda$}3-4, {$\lambda$}5 providing significant information. The WPT method performed advanced filtering of the vibration signal in the mid-to-high DDA frequency range (6250--9375\,Hz), and the high ADA frequency (9375--12500\,Hz) packets provided the excitation ranges that most correlated to surface finish. The advanced SSA and WPT methods provided excellent predictive models with high predictive power and reliability, and optimum vibration signal feature extraction, with the WPT method showing the best results. The analytical-computational performance of the advanced WPT and SSA methods varied significantly. The WPT method had a short processing time, particularly suited for real-time applications; whereas the SSA method had a long processing time that limits its use to off-line applications. An optimum prediction level was determined for the real-time monitoring surface finish using on-line signals captured by one single low-cost sensor (accelerometer), applied to a CNC turning machine under the tested machining conditions. Finally, the results of the comparison of the four signal feature extraction methods underscored the WPT method was the best option for implementing in on-line signal systems for the real-time monitoring of surface finish, using vibration signals in turning operations.},
  keywords = {CNC machining,Signal feature extraction,Surface finish monitoring,Vibration signal},
  annotation = {JCR分区: Q1\\
中科院分区升级版: 工程技术1区\\
影响因子: 6.1\\
5年影响因子: 6.2}
}

@article{Gu2023SurfaceRoughnessPrediction,
